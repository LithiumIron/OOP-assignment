public class HallManager {
	private Hall [] hallList = new Hall[50];
	private static int totalNumOfHall = 0;
	private static int hId = 1;

	//auto generate Hall ID
    public static String generateHallID() {
    	String id = "H" + String.format("%03d", hId);
    	hId++;
    	return id;
    }
    
    //add hall
    public void addHall(Hall hall){
    	hallList[totalNumOfHall] = hall;
    	totalNumOfHall ++;
    	System.out.println("\n[SUCCESS] Hall added!");
    }
    
    //view halls
    public void viewHalls(){
    	if(totalNumOfHall == 0){
    		System.out.println("No halls available.");
    	}
    
    
    	System.out.println("\n======================== Hall List ========================");
    	System.out.printf("| %-6s | %-10s | %-20s |\n", "ID", "Capacity", "Layout");
    
    	for (int i = 0; i<totalNumOfHall; i++){
    		Hall h = hallList[i];
    		System.out.printf("| %-6s | %-10d | %-20s |\n",h.getHallID(),h.getCapacity(),h.getLayout());
    	}
    	System.out.println("\nTotal Number of Halls: " + totalNumOfHall);
    
	}

	//search hall
	public Hall searchHall(String hallID){
		for (int i = 0; i< totalNumOfHall; i++){
			if (hallList[i].getHallID().equals(hallID)){
				return hallList[i];
			}
		
		}
		return null;
	}
	
	//delete hall
	public void deleteHall(String hallID){
		boolean found = false;
		
		for (int i = 0; i < totalNumOfHall; i++){
            if (hallList[i].getHallID().equals(hallID)){
                for (int j = i; j < totalNumOfHall - 1; j++){
                    hallList[j] = hallList[j+1];
                }
                totalNumOfHall--;
                System.out.println("Hall deleted!");
                found = true;
                break;
            }
        }
        if (!found){
        	System.out.println("Hall not found!");
        }
	}
}
